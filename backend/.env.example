# ============================================================================
# DIAMOND BODY BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values before starting the server.
# ============================================================================

# --- Server ---
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# --- CORS: comma-separated list of allowed frontend origins ---
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:9999

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://admin:YEc2kWJnSf6c8iO0jFt5SKUw32GJVirh@dpg-d93k0enlk1mc739d36og-a.virginia-postgres.render.com/diamond_body

# --- JWT ---
JWT_ACCESS_SECRET=change_this_to_a_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_string_at_least_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_SECRET=change_this_to_yet_another_long_random_string
JWT_RESET_EXPIRES_IN=1h


# --- Password hashing ---
BCRYPT_ROUNDS=12

# --- File uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# --- Email (Nodemailer / SMTP) ---
# For Gmail: use an App Password, not your real password.
# For development you can leave these blank; emails will be logged to console.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Diamond Body
SMTP_FROM_EMAIL=no-reply@diamondbody.com

# --- Frontend URL (used in password reset emails) ---
FRONTEND_URL=http://localhost:5173

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=300

# --- Seed defaults (used by prisma/seed.js) ---
SUPER_ADMIN_EMAIL=super@diamondbody.com
SUPER_ADMIN_PASSWORD=DiamondSuper2026!
SUPER_ADMIN_NAME=Super Admin

ADMIN_EMAIL=admin@diamondbody.com
ADMIN_PASSWORD=DiamondAdmin2026!
ADMIN_NAME=Diamond Admin

NATION_LEADER_PASSWORD=Diamond2026!
